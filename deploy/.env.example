# === Copie para .env e preencha ===

# Domínio público (sem https://)
APP_DOMAIN=app.seudominio.com.br
APP_URL=https://app.seudominio.com.br
CERTBOT_EMAIL=voce@seudominio.com.br

# Postgres
POSTGRES_USER=ad_app
POSTGRES_PASSWORD=troque-por-uma-senha-forte-32-chars
POSTGRES_DB=ad_prod

# Segredos da aplicação (gere com: openssl rand -hex 48)
JWT_SECRET=troque-me-openssl-rand-hex-48
SESSION_SECRET=troque-me-openssl-rand-hex-48

# SMTP para envio de emails (reset senha, notificações)
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_USER=no-reply@seudominio.com.br
SMTP_PASS=senha-do-smtp
SMTP_FROM="Igreja Conectada <no-reply@seudominio.com.br>"
